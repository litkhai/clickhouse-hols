# ─────────────────────────────────────────────────────────────────────────────
#  kafka-partitioning-ingestion — lab configuration
#  카프카 파티셔닝 인제스천 — 실습 설정
#
#  Edit these and every script + the producer picks them up. Defaults reproduce
#  the slide numbers (10M rows, 10k customers, 8 partitions, lookup id 4242).
# ─────────────────────────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=kpart

# Host-side ports (change if these are taken on your machine, e.g. by another
# lab in this repo — the langfuse lab uses 8123/9000, so this one defaults to 8124/9001)
CLICKHOUSE_HTTP_PORT=8124
CLICKHOUSE_NATIVE_PORT=9001
KAFKA_EXTERNAL_PORT=9094
CONNECT_REST_PORT=8083

# Producer-side bootstrap server (host → Kafka EXTERNAL listener)
KAFKA_BOOTSTRAP=localhost:9094

# Experiment dimensions — keep these consistent across topics for a fair test
ROWS=10000000          # total events produced to EACH topic
NUM_CUSTOMERS=10000    # key cardinality (customer_id range = [0, NUM_CUSTOMERS))
NUM_PARTITIONS=8       # Kafka partitions per topic (= ClickHouse consumers per table)
LOOKUP_CUSTOMER=4242   # the point-lookup key used in every comparison query
