[mysqld]
# -------------------------------------------------------
# ClickPipes CDC 필수 설정
# -------------------------------------------------------

# 서버 고유 ID (복제 환경에서 고유해야 함)
server-id = 1

# Binary Log 활성화
log_bin = mysql-bin

# CDC에 필수: ROW 기반 바이너리 로깅
binlog_format = ROW

# FULL 이미지: before/after 모든 컬럼 값 기록 (ClickPipes 요구사항)
binlog_row_image = FULL

# 메타데이터 전체 포함: 컬럼명 등 메타정보 기록 (ClickPipes 요구사항)
binlog_row_metadata = FULL

# GTID 모드 활성화 (권장: 안정적인 CDC 지원)
gtid_mode = ON
enforce_gtid_consistency = ON

# 바이너리 로그 보존 기간 (일)
binlog_expire_logs_seconds = 604800  # 7일

# 최대 바이너리 로그 파일 크기
max_binlog_size = 100M

# 타임존 설정
default_time_zone = '+00:00'

# 문자셋
character_set_server = utf8mb4
collation_server = utf8mb4_unicode_ci
